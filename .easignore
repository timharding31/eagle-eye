# Dependencies
node_modules/
pnpm-lock.yaml.bak
yarn.lock
# NOTE: package-lock.json is intentionally NOT ignored — it must be uploaded so
# EAS installs with npm (matching .npmrc) and pins exact versions. Without it,
# EAS finds no lockfile and falls back to yarn, which floats deps off our ^
# ranges (e.g. react-native-svg 15.15.4 -> 15.15.5, failing expo-doctor).

# Build outputs
dist/
build/
.turbo/

# Expo & React Native
.expo/
.expo-shared/
eas.local.json
android/
ios/
*.apk
*.ipa

# NOTE: drizzle/ is intentionally NOT ignored here — migrations are imported
# at build time via babel-plugin-inline-import and must be uploaded to EAS.

# Environment variables
.env
.env.local
.env.*.local

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
